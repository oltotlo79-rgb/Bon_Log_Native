# ============================================================
# アプリ用 (Expo CLI が読み込む)
# EXPO_PUBLIC_ 付きはアプリバイナリに埋め込まれる = 公開情報のみ。
# 秘密鍵・サーバー用シークレットを絶対に入れないこと。
# ============================================================
EXPO_PUBLIC_API_BASE_URL=https://www.bon-log.com
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ============================================================
# ビルド時のみ (本番ビルドでは EAS Secrets で管理。ローカルは任意)
# ============================================================
SENTRY_AUTH_TOKEN=

# ============================================================
# Claude Code MCP 用 (開発時の調査専用。アプリコードからは一切使用しない)
# ============================================================
SUPABASE_ACCESS_TOKEN=
