# ============================================================
# アプリ用 (Expo CLI が読み込む)
# EXPO_PUBLIC_ 付きはアプリバイナリに埋め込まれる = 公開情報のみ。
# 秘密鍵・サーバー用シークレットを絶対に入れないこと。
# ============================================================
EXPO_PUBLIC_API_BASE_URL=https://www.bon-log.com
EXPO_PUBLIC_SENTRY_DSN=
# *_IOS_* 系は将来の iOS リリース用 (当面未使用。iOS 互換実装維持のため枠は残す)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
# Google OAuth クライアント ID (Google Cloud Console で取得)
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID     : iOS ネイティブクライアント ID (将来の iOS リリース用)
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID : Android ネイティブクライアント ID (開発・本番ビルドで使用)
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID     : ウェブクライアント ID (serverClientId として使用。
#                                        モバイルでは ID トークンの aud がこの値に一致する)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ============================================================
# ビルド時のみ (本番ビルドでは EAS Secrets で管理。ローカルは任意)
# ============================================================
# Sentry source map upload の公開 slug。production EAS 環境にも同じ値を設定する。
SENTRY_ORG=
SENTRY_PROJECT=
# Sentry source map upload 用の秘密トークン。リポジトリへ実値を保存しない。
SENTRY_AUTH_TOKEN=

# ============================================================
# Claude Code MCP 用 (開発時の調査専用。アプリコードからは一切使用しない)
# ============================================================
SUPABASE_ACCESS_TOKEN=
