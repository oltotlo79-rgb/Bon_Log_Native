{
  "name": "bon-log",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "overrides": {
    "react-test-renderer": "19.2.3"
  },
  "dependencies": {
    "@expo-google-fonts/shippori-mincho": "^0.4.1",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "^5.101.0",
    "expo": "~56.0.11",
    "expo-auth-session": "~56.0.14",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.6",
    "expo-image": "~56.0.11",
    "expo-image-manipulator": "~56.0.19",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-location": "~56.0.19",
    "expo-notifications": "~56.0.17",
    "expo-router": "~56.2.10",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "leaflet": "^1.9.4",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript-helpers": "^0.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-purchases": "^10.4.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@react-native/jest-preset": "^0.85.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "~19.2.2",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "openapi-typescript": "^7.13.0",
    "react-test-renderer": "19.2.3",
    "typescript": "~5.9.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint app lib hooks components __tests__ -- --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "ci:typegen": "node scripts/generate-router-types.mjs",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "maestro test .maestro/",
    "generate:api": "node scripts/generate-api.mjs"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/__tests__/setup.ts"
    ],
    "testPathIgnorePatterns": [
      "__tests__/utils/test-utils\\.tsx$",
      "__tests__/utils/post-card-factory\\.ts$",
      "__tests__/utils/data-factories\\.ts$",
      "__tests__/setup\\.ts$"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|openapi-fetch|openapi-typescript-helpers|expo-auth-session|expo-crypto|@revenuecat/.*|@react-native-google-signin/.*)"
    ],
    "collectCoverageFrom": [
      "app/**/*.{ts,tsx}",
      "lib/**/*.{ts,tsx}",
      "hooks/**/*.{ts,tsx}",
      "components/**/*.{ts,tsx}",
      "!lib/api/generated/**",
      "!**/*.d.ts",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 85,
        "lines": 85,
        "statements": 85
      }
    }
  },
  "private": true
}
